    def add_cart(self, row, final_price):
        if int(row[10] or 0) == 0:
            QMessageBox.warning(self, 'Нет на складе', f'"{row[1]}" отсутствует на складе')
            return
        cursor = conn.cursor()
        cursor.execute(
            "CREATE TABLE IF NOT EXISTS Cart (cart_id INT PRIMARY KEY AUTO_INCREMENT, user_id INT, product_id INT, price DECIMAL(10,2))")
        cursor.execute("INSERT INTO Cart (user_id, product_id, price) VALUES (%s, %s, %s)",
                       (self.user, row[0], final_price))
        QMessageBox.information(self, 'Корзина', f'"{row[1]}" добавлен в корзину')

    def load_cart(self):
        cursor = conn.cursor()
        cursor.execute("""SELECT c.cart_id, p.product_id, p.product_name, c.price
                         FROM Cart c
                         JOIN Products p ON c.product_id = p.product_id
                         WHERE c.user_id = %s""", (self.user,))
        rows = cursor.fetchall()
        dlg = QDialog(self)
        dlg.setWindowTitle('Корзина')
        dlg.setMinimumWidth(480)
        layout = QVBoxLayout(dlg)
        cart_data = []
        for cart_id, product_id, name, price in rows:
            lbl = QLabel(f'{name} — {float(price):.2f} руб.')
            layout.addWidget(lbl)
            cart_data.append((cart_id, product_id, float(price)))
        if not rows:
            layout.addWidget(QLabel('Корзина пуста'))
        total = sum(pp for _, _, pp in cart_data)
        total_lbl = QLabel(f'Итого: {total:.2f} руб.')
        total_lbl.setStyleSheet("font-weight: bold; font-size: 13px;")
        layout.addWidget(total_lbl)

        points = conn.cursor()
        points.execute("SELECT pickup_point_id, full_address FROM Pickup_points")
        points_list = points.fetchall()

        if points_list:
            point_combo = QComboBox()
            for p in points_list:
                point_combo.addItem(p[1], p[0])
            layout.addWidget(QLabel("Пункт выдачи:"))
            layout.addWidget(point_combo)

        order_btn = QPushButton('Заказать всё')
        layout.addWidget(order_btn)

        def do_order():
            if not cart_data:
                QMessageBox.information(dlg, '', 'Корзина пуста')
                return
            pickup_code = str(random.randint(100, 999))
            pickup_id = point_combo.currentData() if points_list else 11
            c2 = conn.cursor()
            c2.execute("""INSERT INTO Orders (user_id, pickup_point_id, pickup_code, status_id, order_date, delivery_date)
                         VALUES (%s, %s, %s, 2, CURDATE(), DATE_ADD(CURDATE(), INTERVAL 7 DAY))""",
                       (self.user, pickup_id, pickup_code))
            order_id = c2.lastrowid
            for cid, pid, pp in cart_data:
                c2.execute("""INSERT INTO OrderItems (order_id, product_id, quantity, price)
                             VALUES (%s, %s, %s, %s)""", (order_id, pid, 1, pp))
                c2.execute("UPDATE Products SET stock_quantity = stock_quantity - 1 WHERE product_id = %s", (pid,))
                c2.execute("DELETE FROM Cart WHERE cart_id=%s", (cid,))
            dlg.accept()
            while self.content_layout.count():
                w = self.content_layout.takeAt(0)
                if w.widget():
                    w.widget().deleteLater()
            self.load_data()
            QMessageBox.information(self, 'Заказ', f'Заказ оформлен! Код получения: {pickup_code}')

        order_btn.clicked.connect(do_order)
        dlg.exec()


