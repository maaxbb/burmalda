def query(sql, params=()):
    cur = conn.cursor()
    cur.execute(sql, params)
    if sql.strip().upper().startswith('SELECT'):
        return cur.fetchall()
    else:
        conn.commit()
        return None

user = {"id": None, "role": "guest", "name": "Гость"}

class Login(QDialog, Ui_LoginDialog):
    def __init__(self):
        super().__init__()
        self.setupUi(self)
        self.pushButton.clicked.connect(self.auth)
        self.pushButton_2.clicked.connect(self.guest)

    def auth(self):
        res = query("""SELECT u.user_id, r.role_name, u.username
                       FROM Users u
                       JOIN Roles r ON u.role_id = r.role_id
                       WHERE u.username=%s AND u.password_hash=%s""",
                    (self.lineEdit_2.text(), self.lineEdit.text()))
        if res:
            global user
            user = {"id": res[0][0], "role": res[0][1], "name": res[0][2]}
            self.accept()
        else:
            QMessageBox.warning(self, "Ошибка", "Неверный логин или пароль")

    def guest(self):
        self.accept()


class OrdersWindow(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Заказы")
        self.resize(800, 600)
        layout = QVBoxLayout()
        self.sort_combo = QComboBox()
        self.sort_combo.addItems(["Дата ↓ (новые)", "Дата ↑ (старые)"])
        self.sort_combo.currentIndexChanged.connect(self.load_orders)
        layout.addWidget(self.sort_combo)
        self.scroll = QScrollArea()
        self.scroll.setWidgetResizable(True)
        self.orders_widget = QWidget()
        self.orders_layout = QVBoxLayout(self.orders_widget)
        self.scroll.setWidget(self.orders_widget)
        layout.addWidget(self.scroll)
        self.setLayout(layout)
        self.load_orders()

    def load_orders(self):
        while self.orders_layout.count():
            w = self.orders_layout.takeAt(0).widget()
            if w: w.deleteLater()
        order_by = "DESC" if self.sort_combo.currentIndex() == 0 else "ASC"
        data = query(f"""SELECT o.order_id, u.username, os.status_name, o.order_date, o.delivery_date,
                                o.pickup_code, p.full_address
                         FROM Orders o
                         JOIN Users u ON o.user_id = u.user_id
                         JOIN Order_statuses os ON o.status_id = os.status_id
                         JOIN Pickup_points p ON o.pickup_point_id = p.pickup_point_id
                         ORDER BY o.order_date {order_by}""")
        for row in data:
            frame = QFrame()
            frame.setFrameStyle(QFrame.Shape.Box)
            frame.setStyleSheet("margin: 5px; padding: 5px;")
            info = QLabel(
                f'<b>Заказ #{row[0]}</b><br>'
                f'Пользователь: {row[1]}<br>'
                f'Статус: {row[2]}<br>'
                f'Дата заказа: {row[3]}<br>'
                f'Дата доставки: {row[4]}<br>'
                f'Код получения: {row[5]}<br>'
                f'Пункт выдачи: {row[6]}'
            )
            info.setTextFormat(Qt.TextFormat.RichText)
            layout = QHBoxLayout(frame)
            layout.addWidget(info)
            self.orders_layout.addWidget(frame)


class AddProductDialog(QDialog, Ui_ProductForm):
    def __init__(self, product=None):
        super().__init__()
        self.setupUi(self)
        self.product = product

        for row in query("SELECT category_id, category_name FROM Categories ORDER BY category_name"):
            self.categ.addItem(row[1], row[0])
        for row in query("SELECT supplier_id, supplier_name FROM Suppliers ORDER BY supplier_name"):
            self.sp.addItem(row[1], row[0])

        if product:
            self.setWindowTitle("Редактировать товар")
            self.name.setText(product[1])
            self.desc.setText(product[2] if product[2] else "")
            for i in range(self.categ.count()):
                if self.categ.itemData(i) == product[11]:
                    self.categ.setCurrentIndex(i)
                    break
            for i in range(self.sp.count()):
                if self.sp.itemData(i) == product[13]:
                    self.sp.setCurrentIndex(i)
                    break
            self.price.setValue(float(product[4]))
            self.un.setText(product[8] if product[8] else "пара")
            self.qn.setValue(int(product[9]))
            self.disc.setValue(float(product[6]) if product[6] else 0)
        else:
            self.setWindowTitle("Добавить товар")

        self.btn_img.clicked.connect(self.load_image)
        self.btn_save.clicked.connect(self.save)

    def load_image(self):
        file, _ = QFileDialog.getOpenFileName(self, "Выбрать фото", "", "Images (*.png *.jpg *.jpeg)")
        if file:
            pixmap = QPixmap(file).scaled(100, 70, Qt.AspectRatioMode.KeepAspectRatio)
            self.photo.setPixmap(pixmap)

    def save(self):
        if not self.name.text():
            QMessageBox.warning(self, "Ошибка", "Введите название товара")
            return

        if self.product:
            query("""UPDATE Products SET product_name=%s, description=%s, category_id=%s, supplier_id=%s,
                     price=%s, unit=%s, stock_quantity=%s, discount_percentage=%s
                     WHERE product_id=%s""",
                  (self.name.text(), self.desc.text(), self.categ.currentData(), self.sp.currentData(),
                   self.price.value(), self.un.text(), self.qn.value(), self.disc.value(), self.product[0]))
            QMessageBox.information(self, "Успех", "Товар обновлен")
        else:
            query("""INSERT INTO Products (product_name, description, category_id, supplier_id,
                     price, unit, stock_quantity, discount_percentage, image_path, article)
                     VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s)""",
                  (self.name.text(), self.desc.text(), self.categ.currentData(), self.sp.currentData(),
                   self.price.value(), self.un.text(), self.qn.value(), self.disc.value(), "default.jpg",
                   f"ART{self.name.text()[:5]}"))
            QMessageBox.information(self, "Успех", "Товар добавлен")
        self.accept()


class Main(QWidget, Ui_MainWindow):
    def __init__(self):
        super().__init__()
        self.setupUi(self)

        role_names = {"Администратор": "Администратор", "Менеджер": "Менеджер", "Клиент": "Клиент", "guest": "Гость"}
        self.setWindowTitle(f"Магазин обуви - {role_names.get(user['role'], user['role'])}")
        self.label.setText(user["name"])
        self.cart = []

        is_admin = user["role"] == "Администратор"
        is_manager = user["role"] == "Менеджер"
        is_client = user["role"] == "Клиент"

        if is_manager or is_admin:
            self.search.textChanged.connect(self.load)
            self.sort.currentIndexChanged.connect(self.load)
            self.cat.currentIndexChanged.connect(self.load)
            self.cat.addItem("все поставщики")
            for row in query("SELECT supplier_name FROM Suppliers ORDER BY supplier_name"):
                self.cat.addItem(row[0])
            self.btn_orders.clicked.connect(self.open_orders)
        else:
            for w in [self.search, self.sort, self.cat, self.btn_orders]:
                w.hide()

        if is_client:
            self.cart_btn = QPushButton("Корзина")
            self.verticalLayout_2.addWidget(self.cart_btn)
            self.cart_btn.clicked.connect(self.show_cart)

        self.btn_add.setVisible(is_admin)
        self.btn_add.clicked.connect(lambda: AddProductDialog().exec() and self.load())
        self.pushButton_2.clicked.connect(self.logout)
        self.load()

    def logout(self):
        global user
        user = {"id": None, "role": "guest", "name": "Гость"}
        self.close()
        login = Login()
        if login.exec() == QDialog.DialogCode.Accepted:
            self.new_main = Main()
            self.new_main.show()

    def open_orders(self):
        self.orders_window = OrdersWindow()
        self.orders_window.show()

    def load(self):
        while self.cards_layout.count():
            w = self.cards_layout.takeAt(0).widget()
            if w: w.deleteLater()

        search = f"%{self.search.text()}%"
        sql = """SELECT p.product_id, p.product_name, p.description, c.category_name,
                        p.price, p.image_path, p.discount_percentage, s.supplier_name,
                        p.unit, p.stock_quantity, p.category_id, p.manufacturer_id, p.supplier_id
                 FROM Products p
                 LEFT JOIN Categories c ON p.category_id = c.category_id
                 LEFT JOIN Suppliers s ON p.supplier_id = s.supplier_id
                 WHERE p.product_name LIKE %s"""
        params = [search]

        if hasattr(self, 'cat') and self.cat.isVisible() and self.cat.currentText() != "все поставщики":
            sql += " AND s.supplier_name = %s"
            params.append(self.cat.currentText())

        sort_map = {"колличество +": "p.stock_quantity ASC", "колличество -": "p.stock_quantity DESC"}
        sort_by = sort_map.get(self.sort.currentText() if hasattr(self, 'sort') else '', 'p.product_id')
        sql += f" ORDER BY {sort_by}"

        for row in query(sql, params):
            self.create_card(row)

    def create_card(self, row):
        frame = QFrame()
        frame.setFrameStyle(QFrame.Shape.Box)

        price = float(row[4]) if row[4] else 0.0
        qty = int(row[9]) if row[9] else 0
        disc = float(row[6]) if row[6] else 0.0

        if qty == 0:
            frame.setStyleSheet("background-color: #ADD8E6;")
        elif disc > 15:
            frame.setStyleSheet("background-color: #2E8B57;")

        img = QLabel()
        try:
            img.setPixmap(QPixmap(f"images/{row[5]}").scaled(100, 100))
        except:
            img.setText("Нет фото")

        if disc > 0:
            final_price = price * (1 - disc / 100)
            price_text = f'<span style="color:red;text-decoration:line-through">{price:.2f}</span> <b>{final_price:.2f}</b> руб.'
        else:
            final_price = price
            price_text = f'{price:.2f} руб.'

        info = QLabel(
            f'<b>{row[3] or "—"} | {row[1]}</b><br>'
            f'{row[2] or "—"}<br>'
            f'Поставщик: {row[7] or "—"}<br>'
            f'Цена: {price_text}<br>'
            f'{row[8] or "шт"} | В наличии: {qty}'
        )
        info.setTextFormat(Qt.TextFormat.RichText)
        info.setWordWrap(True)

        disc_label = QLabel(f'Скидка\n{disc:.0f}%' if disc > 0 else 'Нет\nскидки')
        disc_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        disc_label.setFixedWidth(80)
        disc_label.setFrameShape(QFrame.Shape.Box)

        layout = QHBoxLayout(frame)
        layout.addWidget(img)
        layout.addWidget(info, 1)
        layout.addWidget(disc_label)

        if user["role"] == "Администратор":
            edit_btn = QPushButton("Редактировать")
            edit_btn.clicked.connect(lambda checked, r=row: self.edit(r))
            del_btn = QPushButton("Удалить")
            del_btn.clicked.connect(lambda checked, r=row: self.delete(r))
            layout.addWidget(edit_btn)
            layout.addWidget(del_btn)
        elif user["role"] == "Клиент" and qty > 0:
            add_btn = QPushButton("В корзину")
            add_btn.clicked.connect(lambda checked, r=row, f=final_price: self.add_to_cart(r, f))
            layout.addWidget(add_btn)

        self.cards_layout.addWidget(frame)

    def edit(self, row):
        dialog = AddProductDialog(row)
        if dialog.exec() == QDialog.DialogCode.Accepted:
            self.load()

    def delete(self, row):
        if QMessageBox.question(self, "Удаление", f'Удалить "{row[1]}"?',
                                QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No) == QMessageBox.StandardButton.Yes:
            query("DELETE FROM Products WHERE product_id=%s", (row[0],))
            self.load()

    def add_to_cart(self, row, final_price):
        self.cart.append({
            'product_id': row[0],
            'name': row[1],
            'price': final_price,
            'quantity': 1
        })
        QMessageBox.information(self, "Корзина", f'Товар "{row[1]}" добавлен в корзину')

    def show_cart(self):
        if not self.cart:
            QMessageBox.information(self, "Корзина", "Корзина пуста")
            return

        dlg = QDialog(self)
        dlg.setWindowTitle("Корзина")
        dlg.setMinimumWidth(500)
        layout = QVBoxLayout(dlg)

        total = 0
        for item in self.cart:
            frame = QFrame()
            frame.setFrameStyle(QFrame.Shape.Box)
            lbl = QLabel(f'{item["name"]} - {item["price"]:.2f} руб. x {item["quantity"]}')
            remove_btn = QPushButton("Удалить")
            remove_btn.clicked.connect(lambda checked, i=item: self.remove_from_cart(i, dlg))
            hlayout = QHBoxLayout(frame)
            hlayout.addWidget(lbl)
            hlayout.addWidget(remove_btn)
            layout.addWidget(frame)
            total += item["price"] * item["quantity"]

        layout.addWidget(QLabel(f'<b>Итого: {total:.2f} руб.</b>'))
        order_btn = QPushButton("Оформить заказ")
        order_btn.clicked.connect(lambda: self.create_order(dlg))
        layout.addWidget(order_btn)
        dlg.exec()

    def remove_from_cart(self, item, dlg):
        self.cart.remove(item)
        dlg.close()
        self.show_cart()

    def create_order(self, dlg):
        if not self.cart:
            return

        points = query("SELECT pickup_point_id, full_address FROM Pickup_points")
        if not points:
            QMessageBox.warning(self, "Ошибка", "Нет пунктов выдачи")
            return

        point_dlg = QDialog(self)
        point_dlg.setWindowTitle("Выберите пункт выдачи")
        layout = QVBoxLayout(point_dlg)

        for point in points:
            btn = QPushButton(point[1])
            btn.clicked.connect(lambda checked, p=point: self.finalize_order(p[0], dlg, point_dlg))
            layout.addWidget(btn)

        point_dlg.exec()

    def finalize_order(self, pickup_point_id, cart_dlg, point_dlg):
        import random
        pickup_code = str(random.randint(100, 999))

        cursor = conn.cursor()
        cursor.execute("""INSERT INTO Orders (user_id, pickup_point_id, pickup_code, status_id, order_date, delivery_date)
                         VALUES (%s, %s, %s, 2, CURDATE(), DATE_ADD(CURDATE(), INTERVAL 7 DAY))""",
                       (user["id"], pickup_point_id, pickup_code))
        order_id = cursor.lastrowid

        for item in self.cart:
            cursor.execute("""INSERT INTO OrderItems (order_id, product_id, quantity, price)
                             VALUES (%s, %s, %s, %s)""",
                           (order_id, item["product_id"], item["quantity"], item["price"]))
            cursor.execute("UPDATE Products SET stock_quantity = stock_quantity - %s WHERE product_id = %s",
                           (item["quantity"], item["product_id"]))

        self.cart.clear()
        cart_dlg.close()
        point_dlg.close()
        QMessageBox.information(self, "Заказ", f"Заказ оформлен! Код получения: {pickup_code}")
        self.load()


if __name__ == "__main__":
    app = QApplication(sys.argv)
    login = Login()
    if login.exec() == QDialog.DialogCode.Accepted:
        window = Main()
        window.show()
        sys.exit(app.exec())











